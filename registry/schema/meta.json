        "minFusions": 3,
        "minOriginContributions": 1
      }
    },
    "6★": {
      "description": "Grandmaster path: hold 2+ 5★ Ultimate skills AND the proposer's GitHub repo has 10k+ stars.",
      "grandmasterPath": {
        "minUltimateSkills": 2,
        "minUltimateLevel": "5★",
        "minRepoStars": 10000
      }
    }
