#!/usr/bin/env bash
set -euo pipefail

changed="$(git diff --cached --name-only)"
if [ -z "$changed" ]; then
  exit 0
fi

version_files=(
  pyproject.toml
  packages/cli-npm/package.json
  packages/mcp/package.json
  registry/gaia.json
)

generated_paths=(
  registry/registry.md
  registry/combinations.md
  registry/skills
  registry/gaia.gexf
  registry/gaia.svg
  registry/render
  registry/named-skills.json
  registry/real-skills.html
  registry/real-skills.md
  docs/graph/gaia.json
  docs/graph/gaia.gexf
  docs/graph/gaia.svg
  docs/graph/named/index.json
  docs/tree.md
  README.md
  docs/index.html
)

classify_bump() {
  local msg
  msg="$(git log --format=%B -n 1 HEAD 2>/dev/null || true)"
  if [ -f .git/COMMIT_EDITMSG ]; then
    msg="$msg"$'\n'"$(cat .git/COMMIT_EDITMSG)"
  fi
  if printf '%s\n' "$msg" | grep -Eq 'BREAKING CHANGE|^[a-zA-Z]+(\([^)]*\))?!:'; then
    printf 'major'
  elif printf '%s\n' "$msg" | grep -Eq '^feat(\([^)]*\))?:'; then
    printf 'minor'
  else
    printf 'patch'
  fi
}

printf 'Gaia pre-commit: checking version lockstep...\n'
python3 - <<'PY'
from gaia_cli.versioning import ensure_versions_in_sync
ensure_versions_in_sync(".")
PY

bump="$(classify_bump)"
printf 'Gaia pre-commit: applying %s version bump...\n' "$bump"
python3 - <<PY
from gaia_cli.versioning import bump_versions
print(bump_versions(".", "$bump"))
PY
git add "${version_files[@]}"

if printf '%s\n' "$changed" | grep -Eq '^(registry/gaia\.json|registry/named/|registry-for-review/skill-batches/|scripts/generateProjections\.py|scripts/exportGexf\.py|scripts/renderGraphSvg\.py|scripts/generateNamedIndex\.py|scripts/generateRealSkills\.py)'; then
  printf 'Gaia pre-commit: validating and regenerating registry artifacts...\n'
  python3 scripts/validate.py
  python3 scripts/validate_intake.py
  python3 scripts/generateProjections.py
  python3 scripts/exportGexf.py
  gaia graph --format svg --output registry/gaia.svg --no-open
  gaia graph --format json --output registry/render/latest.json --no-open
  gaia graph --format html --output registry/render/gaia.html --no-open
  python3 scripts/syncDocsGraphAssets.py
fi

printf 'Gaia pre-commit: rebuilding generated docs regions...\n'
gaia docs build

git add "${generated_paths[@]}" 2>/dev/null || true

printf 'Gaia pre-commit: done.\n'
