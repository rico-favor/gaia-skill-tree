# Gaia Skill Registry — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.eggs/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Claude Code agent worktrees (ephemeral isolated checkouts)
.claude/worktrees/
# Claude runtime lock files (machine-local PIDs — never commit)
.claude/scheduled_tasks.lock

# Impeccable live-edit session state (ephemeral DOM snapshots)
.impeccable/live/sessions/

# Plugin local cache
.gaia/
.gaia/skill-tree.cache.json
generated-output/

# Temp files
*.tmp
*.bak
scratch/
.hermes
